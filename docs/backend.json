
{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with comprehensive personal details",
      "type": "object",
      "properties": {
        "userCode": { "type": "string", "description": "Unique login code" },
        "firstName": { "type": "string", "description": "First name" },
        "lastName": { "type": "string", "description": "Last name" },
        "dob": { "type": "string", "format": "date" },
        "mobile": { "type": "string" },
        "personalEmail": { "type": "string", "format": "email" },
        "bloodType": { "type": "string", "enum": ["A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"] },
        "emergencyContact": { "type": "string" },
        "role": { "type": "string", "enum": ["SuperAdmin", "Resident"] },
        "roomUnit": { "type": "string" },
        "monthlyRent": { "type": "number" },
        "billingDays": { "type": "number" },
        "isMiscApplicable": { "type": "boolean" }
      },
      "required": ["userCode", "role", "firstName", "lastName"]
    },
    "UtilityBill": {
      "title": "Utility Bill",
      "description": "Monthly utility expenses for the shared household",
      "type": "object",
      "properties": {
        "monthYear": { "type": "string" },
        "wifi": { "type": "number" },
        "water": { "type": "number" },
        "electricity": { "type": "number" },
        "miscellaneous": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Draft", "Released"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["monthYear", "wifi", "water", "electricity"]
    },
    "MaintenanceRequest": {
      "title": "Maintenance Request",
      "description": "Request for repairs from residents",
      "type": "object",
      "properties": {
        "residentId": { "type": "string" },
        "residentName": { "type": "string" },
        "roomUnit": { "type": "string" },
        "category": { "type": "string", "enum": ["Plumbing", "Electrical", "Structural", "Other"] },
        "urgency": { "type": "string", "enum": ["Low", "Medium", "High", "Emergency"] },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "In Progress", "Resolved", "Cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "adminNotes": { "type": "string" }
      },
      "required": ["residentId", "category", "urgency", "description", "status"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/User",
      "description": "User profiles"
    },
    "/utility_bills/{billId}": {
      "schema": "#/entities/UtilityBill",
      "description": "Utility records"
    },
    "/maintenance_requests/{requestId}": {
      "schema": "#/entities/MaintenanceRequest",
      "description": "Repairs and maintenance requests"
    }
  }
}
