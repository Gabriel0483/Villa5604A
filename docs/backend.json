
{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with comprehensive personal details",
      "type": "object",
      "properties": {
        "userCode": { "type": "string", "description": "Unique login code" },
        "firstName": { "type": "string", "description": "First name" },
        "lastName": { "type": "string", "description": "Last name" },
        "dob": { "type": "string", "format": "date", "description": "Date of Birth" },
        "mobile": { "type": "string", "description": "Mobile contact number" },
        "personalEmail": { "type": "string", "format": "email", "description": "Optional personal email" },
        "bloodType": { "type": "string", "enum": ["A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"], "description": "Blood type for medical emergencies" },
        "emergencyContact": { "type": "string", "description": "Emergency contact phone number" },
        "role": { "type": "string", "enum": ["SuperAdmin", "Resident"], "description": "Access level" },
        "roomUnit": { "type": "string", "description": "Assigned room or unit number" },
        "monthlyRent": { "type": "number", "description": "Monthly rent amount assigned to this resident in OMR" },
        "billingDays": { "type": "number", "description": "Number of days the resident is billed for in the cycle (default 30)" },
        "isMiscApplicable": { "type": "boolean", "description": "Whether miscellaneous expenses apply to this resident" }
      },
      "required": ["userCode", "role", "firstName", "lastName"]
    },
    "UtilityBill": {
      "title": "Utility Bill",
      "description": "Monthly utility expenses for the shared household",
      "type": "object",
      "properties": {
        "monthYear": { "type": "string", "description": "Month and Year of the bill (YYYY-MM)" },
        "wifi": { "type": "number", "description": "Wifi bill amount in OMR" },
        "water": { "type": "number", "description": "Water bill amount in OMR" },
        "electricity": { "type": "number", "description": "Electricity bill amount in OMR" },
        "miscellaneous": { "type": "number", "description": "Other shared expenses in OMR" },
        "total": { "type": "number", "description": "Sum of all utilities in OMR" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["monthYear", "wifi", "water", "electricity"]
    },
    "MaintenanceRequest": {
      "title": "Maintenance Request",
      "description": "A request for repairs or maintenance in the villa",
      "type": "object",
      "properties": {
        "residentId": { "type": "string" },
        "residentName": { "type": "string" },
        "roomUnit": { "type": "string" },
        "category": { "type": "string", "enum": ["Plumbing", "Electrical", "Appliance", "Furniture", "Other"] },
        "urgency": { "type": "string", "enum": ["Low", "Medium", "High", "Emergency"] },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "In Progress", "Completed", "Cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["residentId", "category", "urgency", "description", "status"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/User",
      "description": "Collection of user profiles"
    },
    "/utility_bills/{billId}": {
      "schema": "#/entities/UtilityBill",
      "description": "Monthly utility bill records"
    },
    "/maintenance_requests/{requestId}": {
      "schema": "#/entities/MaintenanceRequest",
      "description": "Collection of maintenance and repair requests"
    }
  }
}
