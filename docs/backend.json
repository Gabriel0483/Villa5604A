
{
  "entities": {
    "Tenant": {
      "title": "Tenant",
      "description": "Information about a tenant and their lease agreement.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the tenant" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "phone": { "type": "string", "description": "Phone number" },
        "propertyAddress": { "type": "string", "description": "The address of the rented property" },
        "rentAmount": { "type": "number", "description": "Monthly rent amount" },
        "status": { "type": "string", "enum": ["active", "past", "pending"], "description": "Current status of the tenant" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the record was created" }
      },
      "required": ["name", "email", "propertyAddress", "rentAmount"]
    },
    "User": {
      "title": "User",
      "description": "User profile with comprehensive personal details",
      "type": "object",
      "properties": {
        "userCode": { "type": "string", "description": "Unique login code" },
        "firstName": { "type": "string", "description": "First name" },
        "lastName": { "type": "string", "description": "Last name" },
        "dob": { "type": "string", "format": "date", "description": "Date of Birth" },
        "mobile": { "type": "string", "description": "Mobile contact number" },
        "personalEmail": { "type": "string", "format": "email", "description": "Optional personal email" },
        "bloodType": { "type": "string", "enum": ["A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"], "description": "Blood type for medical emergencies" },
        "emergencyContact": { "type": "string", "description": "Emergency contact phone number" },
        "role": { "type": "string", "enum": ["SuperAdmin", "Resident"], "description": "Access level" },
        "tenantId": { "type": "string", "description": "Reference to tenant record if role is Resident" },
        "roomUnit": { "type": "string", "description": "Assigned room or unit number" },
        "monthlyRent": { "type": "number", "description": "Monthly rent amount assigned to this resident" }
      },
      "required": ["userCode", "role", "firstName", "lastName"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/tenants/{tenantId}": {
      "schema": "#/entities/Tenant",
      "description": "Collection of tenant records"
    },
    "/users/{userId}": {
      "schema": "#/entities/User",
      "description": "Collection of user profiles"
    }
  }
}
