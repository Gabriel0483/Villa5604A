rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to get the current user's role from Firestore
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper function to check if the user is a SuperAdmin
    // We check both the primary email and the portal-specific dummy emails
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'rielmagpantay@gmail.com' ||
        request.auth.token.email == 'rielmagpantay@gmail.com@villa5604.app' ||
        request.auth.token.email == 'room101@villa5604.app' ||
        getUserData().role == 'SuperAdmin'
      );
    }

    // Tenant records - Only SuperAdmins can manage tenant lease records
    match /tenants/{tenantId} {
      allow read, write: if isSuperAdmin();
    }

    // User profiles
    match /users/{userId} {
      // Users can read and write their own profile
      // SuperAdmins can read and write all profiles (for role management)
      allow read: if isSuperAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow write: if isSuperAdmin() || (isSignedIn() && request.auth.uid == userId);
    }
  }
}