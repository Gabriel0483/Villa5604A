rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the user is a SuperAdmin
    function isSuperAdmin() {
      let adminEmails = [
        'rielmagpantay@gmail.com',
        'rielmagpantay@gmail.com@villa5604.app',
        'room101@villa5604.app'
      ];
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && (
        request.auth.token.email in adminEmails ||
        (exists(userPath) && get(userPath).data.role == 'SuperAdmin')
      );
    }

    // User profiles: Users can read/write their own, admins can do everything
    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    // Utility bills: All signed-in users can read, only admins can write
    match /utility_bills/{billId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Maintenance requests: Residents can create and read their own. Admins manage everything.
    match /maintenance_requests/{requestId} {
      // Allow read if the document belongs to the user OR user is admin
      allow read: if isSignedIn() && (isSuperAdmin() || resource.data.residentId == request.auth.uid);
      
      // Allow create if the user identifies themselves correctly
      allow create: if isSignedIn() && request.resource.data.residentId == request.auth.uid;
      
      // Allow update/delete if owner or admin
      allow update, delete: if isSignedIn() && (isSuperAdmin() || resource.data.residentId == request.auth.uid);
    }
  }
}