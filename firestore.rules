rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the user is a SuperAdmin
    function isSuperAdmin() {
      let adminEmails = [
        'rielmagpantay@gmail.com',
        'rielmagpantay@gmail.com@villa5604.app',
        'room101@villa5604.app'
      ];
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && (
        request.auth.token.email in adminEmails ||
        (exists(userPath) && get(userPath).data.role == 'SuperAdmin')
      );
    }

    // User profiles: Users can read/write their own, admins can do everything
    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    // Utility bills: All signed-in users can read, only admins can write
    match /utility_bills/{billId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Maintenance requests: Residents can create and read their own history, admins see all
    match /maintenance_requests/{requestId} {
      // Allow creation for any signed-in user
      allow create: if isSignedIn();
      
      // Allow reading if admin or if the request belongs to the resident
      allow read: if isSignedIn() && (
        isSuperAdmin() || 
        (resource != null && resource.data.residentId == request.auth.uid)
      );
      
      // Only admins can update status or delete
      allow update, delete: if isSuperAdmin();
    }

    // Legacy tenant records (Administrative only)
    match /tenants/{tenantId} {
      allow read, write: if isSuperAdmin();
    }
  }
}