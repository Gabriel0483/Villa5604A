
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      let adminEmails = [
        'rielmagpantay@gmail.com',
        'rielmagpantay@gmail.com@villa5604.app',
        'room101@villa5604.app'
      ];
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && (
        request.auth.token.email in adminEmails ||
        (exists(userPath) && get(userPath).data.role == 'SuperAdmin')
      );
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    match /utility_bills/{billId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /maintenance_requests/{requestId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.residentId == request.auth.uid || isSuperAdmin());
      allow write: if isSuperAdmin();
    }
  }
}
