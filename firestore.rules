
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the user is a SuperAdmin
    function isSuperAdmin() {
      let adminEmails = [
        'rielmagpantay@gmail.com',
        'rielmagpantay@gmail.com@villa5604.app',
        'room101@villa5604.app'
      ];
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && (
        request.auth.token.email in adminEmails ||
        (exists(userPath) && get(userPath).data.role == 'SuperAdmin')
      );
    }

    // Tenant records (Administrative only)
    match /tenants/{tenantId} {
      allow read, write: if isSuperAdmin();
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSuperAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow write: if isSuperAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // Utility bills
    match /utility_bills/{billId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Maintenance requests
    match /maintenance_requests/{requestId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (isSuperAdmin() || resource.data.residentId == request.auth.uid);
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }
  }
}
