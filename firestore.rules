rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the user is a SuperAdmin
    // Grants access if the email matches the specific admin email or if the role is 'SuperAdmin' in Firestore
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'rielmagpantay@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin'
      );
    }

    // Tenant records
    match /tenants/{tenantId} {
      // Explicitly allow SuperAdmins full access
      // Maintaining temporary open access for development as per previous instructions
      allow read, write: if isSuperAdmin() || request.time < timestamp.date(2026, 6, 7);
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if isSuperAdmin() || (isSignedIn() && request.auth.uid == userId) || request.time < timestamp.date(2026, 6, 7);
    }
  }
}