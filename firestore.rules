
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // sync-trigger: v12-role-enforcement

    // Comprehensive SuperAdmin check
    function isSuperAdmin() {
      let adminEmails = [
        'rielmagpantay@gmail.com',
        'rielmagpantay@gmail.com@villa5604.app',
        'room101@villa5604.app',
        'admin001@villa5604.app'
      ];
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email.lower() in adminEmails) ||
        (exists(userPath) && get(userPath).data.role == 'SuperAdmin')
      );
    }

    match /users/{userId} {
      // Allow all signed-in users to read basic profile info for billing transparency
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    match /utility_bills/{billId} {
      // Residents can view household utility totals as a dashboard snapshot even before release.
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /maintenance_requests/{requestId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        (resource != null && resource.data.residentId == request.auth.uid) || 
        isSuperAdmin()
      );
      allow update, delete: if isSuperAdmin();
    }
  }
}
